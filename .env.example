# S3 Storage Backend
# Choose one: Infomaniak, Backblaze B2, AWS S3, MinIO, etc.

# Infomaniak S3
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your-bucket-name
S3_ENDPOINT=https://s3.pub1.infomaniak.cloud

# Alternative: Backblaze B2 (uncomment to use instead)
# S3_ACCESS_KEY_ID=your_b2_key_id
# S3_SECRET_ACCESS_KEY=your_b2_secret_key
# S3_BUCKET=your-bucket-name
# S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# Plakar encryption passphrase
PLAKAR_PASSPHRASE=your_strong_passphrase

# Backup source path on NAS
BACKUP_SOURCE=/volume1/data

# (Optional) Container user UID:GID for file permissions
# On Synology, you can find UID/GID with: id service.docker
# Default: 1000:1000 (plakar user inside container)
# PLAKAR_UID=1000
# PLAKAR_GID=1000
